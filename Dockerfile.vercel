# Dockerfile que Vercel detecta para construir y servir la imagen como contenedor.
# Mismo enfoque que el Dockerfile local: build de Angular + Nginx sirviendo en el puerto 80.
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist/liquid-pricing-ng/browser /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
